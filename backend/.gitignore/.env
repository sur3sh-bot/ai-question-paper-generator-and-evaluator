# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ─── Upload settings ──────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=20
UPLOAD_DIR=uploads

# ─── Question generation settings ────────────────────────────────────────────
# Number of questions to generate per text chunk
QUESTIONS_PER_CHUNK=3
# OpenAI model to use
OPENAI_MODEL=gpt-4o-mini
